# ── Required ──────────────────────────────────────────────────────────────────

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Your Discord application/client ID
# Found on the Discord Developer Portal → your app → OAuth2 → Client ID
DISCORD_CLIENT_ID=your_client_id_here

# The ID of the channel where chapter announcements will be posted
# Right-click a channel in Discord → "Copy Channel ID" (enable Developer Mode first)
DISCORD_CHANNEL_ID=your_channel_id_here

# ── Optional ──────────────────────────────────────────────────────────────────

# How often to check nyaa.si in milliseconds. Default: 300000 (5 minutes)
# Don't go below 60000 (1 minute) to avoid hammering nyaa's servers.
CHECK_INTERVAL_MS=300000
